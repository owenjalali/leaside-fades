PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leaside_fades

# Barber profile photo uploads
# Production uses Vercel Blob through BLOB_READ_WRITE_TOKEN.
# Local QA may set TEAM_PROFILE_IMAGE_UPLOAD_MODE=mock to exercise the upload API without external writes.
BLOB_READ_WRITE_TOKEN=
TEAM_PROFILE_IMAGE_UPLOAD_MODE=

# Local/dev-only auth bootstrap
DEV_OWNER_EMAIL=owner@example.com
DEV_OWNER_PASSWORD=replace-with-local-dev-password
DEV_OWNER_NAME=Local Dev Owner

# Notifications
# NOTIFICATION_DELIVERY_MODE values:
# - mock: local/default mode; no Twilio or Brevo credentials required.
# - dev: logs SMS/email payloads to the server console without live sends.
# - live: sends email through Brevo and uses SMS_DELIVERY_MODE for Twilio.
NOTIFICATION_DELIVERY_MODE=mock
# Set paused to retain Twilio configuration without sending or retrying SMS.
SMS_DELIVERY_MODE=paused
# Bound each external provider request. Runtime clamps this to 1-10 seconds.
NOTIFICATION_PROVIDER_TIMEOUT_MS=5000
REMINDER_JOB_LOOKBACK_MINUTES=60
REMINDER_JOB_LOOKAHEAD_MINUTES=15
# HTTP scheduler guard for /api/jobs/send-reminders. Use 30 on quota-limited DB plans;
# use 5 only when the production database plan can sustain five-minute wakeups.
REMINDER_HTTP_MIN_INTERVAL_MINUTES=30
REMINDER_HTTP_BOUNDARY_GRACE_MINUTES=2
# The HTTP route uses one PostgreSQL connection and bounded initialization/work budgets.
REMINDER_DB_CONNECT_TIMEOUT_MS=4000
REMINDER_DB_QUERY_TIMEOUT_MS=5000
REMINDER_HTTP_DEADLINE_MS=24000
CRON_SECRET=
# Before enabling production cron, set NOTIFICATION_DELIVERY_MODE=live and run:
# npm run notifications:check-live-config
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BREVO_API_KEY=
EMAIL_FROM="Leaside Fades <bookings@leasidefades.com>"
EMAIL_REPLY_TO=

# Google Places API (server-side only)
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=your_google_place_id

# Public site configuration
SITE_BUSINESS_NAME=Leaside Fades
SITE_PHONE_E164=+16473482200
SITE_PHONE_DISPLAY=+1 (647) 348-2200
SITE_GOOGLE_MAPS_URL=https://www.google.com/maps/place/Leaside+Fades/@43.7137557,-79.3678747,17z/data=!3m1!4b1!4m6!3m5!1s0x89d4cd3cbeae8bc3:0xc528126035583aff!8m2!3d43.7137557!4d-79.3652998!16s%2Fg%2F11xmhwymps?entry=ttu&g_ep=EgoyMDI2MDIxNi4wIKXMDSoASAFQAw%3D%3D
SITE_INSTAGRAM_URL=https://www.instagram.com/explore/locations/108041690603158/leaside-fades/
SITE_FACEBOOK_URL=https://www.facebook.com/p/Leaside-FADES-100067481677284/
# Local/dev should point at the in-app booking flow. Production uses https://leasidefades.com/book.
SITE_BOOKING_URL=http://localhost:3000/book
SITE_BOOKING_NOTICE=Book online with Leaside Fades.
