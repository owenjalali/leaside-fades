{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "functions": {
    "api/[...route].js": {
      "maxDuration": 30,
      "includeFiles": "src/server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...route]"
    },
    {
      "source": "/book",
      "destination": "/index.html"
    },
    {
      "source": "/book/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/booking",
      "destination": "/index.html"
    },
    {
      "source": "/booking/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    }
  ]
}
