# Leaside Fades production environment template.
# Copy this file to .env on the production host, or enter the same keys
# in your hosting provider's environment-variable dashboard.
#
# Do not commit a filled-in .env file. The real .env file is gitignored.

NODE_ENV=production
PORT=3000
APP_URL=https://leasidefades.com

# PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Do not set DEV_OWNER_* values in production. Local/dev seed scripts refuse
# non-local database hosts and must not be used to create production data.

# Notification delivery
# Use mock/dev locally. Use live only when Twilio, Resend, and production DB are ready.
NOTIFICATION_DELIVERY_MODE=live
REMINDER_JOB_LOOKBACK_MINUTES=60
REMINDER_JOB_LOOKAHEAD_MINUTES=15
# HTTP scheduler guard for /api/jobs/send-reminders. Keep 30 on quota-limited DB plans;
# set to 5 only after the database plan can sustain five-minute wakeups.
REMINDER_HTTP_MIN_INTERVAL_MINUTES=30
CRON_SECRET=replace-with-long-random-secret

# Twilio SMS
# Account SID usually starts with AC. Phone number must be E.164, for example +16475550199.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Resend email
# Use a verified sender domain/address in Resend.
RESEND_API_KEY=
EMAIL_FROM="Leaside Fades <bookings@leasidefades.com>"

# Google Places reviews
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJw4uuvjzN1IkR_zpYNWASKMU

# Public site configuration
SITE_BUSINESS_NAME=Leaside Fades
SITE_PHONE_E164=+16473482200
SITE_PHONE_DISPLAY=+1 (647) 348-2200
SITE_GOOGLE_MAPS_URL=https://www.google.com/maps/place/Leaside+Fades/@43.7137557,-79.3678747,17z/data=!3m1!4b1!4m6!3m5!1s0x89d4cd3cbeae8bc3:0xc528126035583aff!8m2!3d43.7137557!4d-79.3652998!16s%2Fg%2F11xmhwymps?entry=ttu&g_ep=EgoyMDI2MDIxNi4wIKXMDSoASAFQAw%3D%3D
SITE_INSTAGRAM_URL=https://www.instagram.com/explore/locations/108041690603158/leaside-fades/
SITE_FACEBOOK_URL=https://www.facebook.com/p/Leaside-FADES-100067481677284/
SITE_BOOKING_URL=https://leasidefades.com/book
SITE_BOOKING_NOTICE=Book online with Leaside Fades.
